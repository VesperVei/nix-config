{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.pem": "deny",
      "*.key": "deny",
      "*kubeconfig*": "deny",
      ".ssh/**": "deny",
      ".aws/**": "deny",
      ".kube/**": "deny",
      ".gnupg/**": "deny",
      "~/nix-secrets/**": "deny",
      "/run/agenix/**": "deny"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "task": "allow",
    "lsp": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": "ask",
    "doom_loop": "deny",
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git remote *": "allow",
      "git tag *": "allow",
      "git blame *": "allow",
      "git reflog *": "allow",
      "git stash list *": "allow",
      "nix eval *": "allow",
      "nix build *": "allow",
      "nix flake *": "allow",
      "nix profile *": "allow",
      "nix store *": "allow",
      "nix search *": "allow",
      "nix doctor *": "allow",
      "darwin-rebuild build *": "allow",
      "home-manager build *": "allow",
      "nh home build *": "allow",
      "just --list *": "allow",
      "just --show *": "allow",
      "just --dry-run *": "allow",
      "statix check *": "allow",
      "deadnix *": "allow",
      "nixfmt *": "allow",
      "shellcheck *": "allow",
      "prettier --check *": "allow",
      "ruff check *": "allow",
      "node --version *": "allow",
      "pnpm list *": "allow",
      "uv pip list *": "allow",
      "python3 --version *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "ls *": "allow",
      "pwd *": "allow",
      "date *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "tree *": "allow",
      "bat *": "allow",
      "eza *": "allow",
      "jq *": "allow",
      "rm *": "ask",
      "git push *": "ask",
      "git commit *": "ask",
      "nh darwin switch *": "ask",
      "nh home switch *": "ask",
      "darwin-rebuild switch *": "ask",
      "rm -rf *": "deny",
      "git reset --hard *": "deny",
      "git push --force *": "deny",
      "cat /run/agenix/*": "deny"
    }
  }
}
